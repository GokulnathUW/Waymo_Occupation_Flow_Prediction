filenames = tf.io.matching_files(TRAIN_FILES)               # Get all the training files
dataset = tf.data.TFRecordDataset(filenames)                # Create a dataset of tf.Example protos.
dataset = dataset.repeat()                                  # Repeat the dataset indefinitely. Useful for training multiple epochs
dataset = dataset.map(occupancy_flow_data.parse_tf_example) # Parse the tf.Example protos into a dataset of (input, output) pairs.
dataset = dataset.batch(1)                                  # Batch the dataset.
it = iter(dataset)                                          # Create an iterator over the dataset.

inputs = next(it)
inputs_no_batch = {k: v[0] for k, v in inputs.items()} # first example in batch
images = visualize_all_agents_smooth(inputs_no_batch)
anim = create_animation(images[::5])
HTML(anim.to_html5_video())